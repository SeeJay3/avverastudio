---
type Project = {
  tag: string;
  icon: 'palette' | 'feed' | 'network' | 'diagnostic' | 'camera' | 'pen';
};

const projects: Project[] = [
  { tag: 'Identidade Visual', icon: 'palette' },
  { tag: 'Feed Estratégico', icon: 'feed' },
  { tag: 'Gestão de Redes', icon: 'network' },
  { tag: 'Diagnóstico + Plano de Ação', icon: 'diagnostic' },
  { tag: 'Produção de Conteúdo', icon: 'camera' },
  { tag: 'Copywriting', icon: 'pen' },
];
---

<section id="portfolio">
  <p class="section-label gsap-fade">Portfólio</p>
  <h2 class="section-title gsap-fade">Alguns dos nossos <em>projetos</em></h2>
  <div class="portfolio-grid">
    {
      projects.map((p) => (
        <div class="portfolio-item gsap-fade">
          <div class="portfolio-icon">
            {p.icon === 'palette' && (
              <svg viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10c1.66 0 3-1.34 3-3 0-.78-.31-1.5-.81-2.03-.49-.5-.79-1.21-.79-1.97 0-1.66 1.34-3 3-3h2c2.21 0 4-1.79 4-4 0-4.42-4.48-8-10-8z" />
                <circle cx="6.5" cy="11.5" r="1.5" />
                <circle cx="9.5" cy="7.5" r="1.5" />
                <circle cx="14.5" cy="7.5" r="1.5" />
                <circle cx="17.5" cy="11.5" r="1.5" />
              </svg>
            )}
            {p.icon === 'feed' && (
              <svg viewBox="0 0 24 24">
                <rect x="3" y="3" width="8" height="8" rx="1" />
                <rect x="13" y="3" width="8" height="8" rx="1" />
                <rect x="3" y="13" width="8" height="8" rx="1" />
                <rect x="13" y="13" width="8" height="8" rx="1" />
              </svg>
            )}
            {p.icon === 'network' && (
              <svg viewBox="0 0 24 24">
                <circle cx="6" cy="12" r="2.5" />
                <circle cx="18" cy="5" r="2.5" />
                <circle cx="18" cy="19" r="2.5" />
                <line x1="8.2" y1="10.8" x2="15.8" y2="6.2" />
                <line x1="8.2" y1="13.2" x2="15.8" y2="17.8" />
              </svg>
            )}
            {p.icon === 'diagnostic' && (
              <svg viewBox="0 0 24 24">
                <circle cx="11" cy="11" r="7" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
                <polyline points="8 11 10 13 14 9" />
              </svg>
            )}
            {p.icon === 'camera' && (
              <svg viewBox="0 0 24 24">
                <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                <circle cx="12" cy="13" r="4" />
              </svg>
            )}
            {p.icon === 'pen' && (
              <svg viewBox="0 0 24 24">
                <path d="M12 19l7-7 3 3-7 7-3-3z" />
                <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z" />
                <line x1="2" y1="2" x2="9.586" y2="9.586" />
                <circle cx="11" cy="11" r="2" />
              </svg>
            )}
          </div>
          <span class="portfolio-tag">{p.tag}</span>
        </div>
      ))
    }
  </div>
</section>
